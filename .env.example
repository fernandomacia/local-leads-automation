# External API for lead sync (optional — pipeline runs fine without it)
API_URL=https://your-backend.com/api/leads
API_KEY=your_api_key_here

# Sender identity used in outreach email templates
SENDER_NAME=your_name_here
SENDER_COMPANY=your_company_here

# Local LLM for message generation (Hugging Face model ID)
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
