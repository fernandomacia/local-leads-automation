# SegurSEO-API job queue
API_BASE_URL=http://localhost:8000
API_TOKEN=your_worker_token_here
BATCH_SIZE=10
POLL_INTERVAL=10

# Company name used in outreach email templates
SENDER_COMPANY=your_company_here

# OpenRouter for message generation (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=your_openrouter_model_id_here
